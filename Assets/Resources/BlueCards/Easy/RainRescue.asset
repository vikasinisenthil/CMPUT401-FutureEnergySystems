  m_Script: {fileID: 11500000, guid: 88074e2e0d4f0b8478a99308a4b0d6a4, type: 3}
  m_Name: RainRescue
  m_EditorClassIdentifier: GameScripts::BlueMCQCard
  cardName: Rain to the Rescue
  image: {fileID: 21300000, guid: e8f4b00f3deb21542a61a6aaaca9ca1e, type: 3}
  statement: 
  question: True or False - Cold air can hold more water than warm air.
  answers:
  - answer: True
    messageWhenChosen: "True! Rain gives the sky a bath. Raindrops and snowflakes
      act like tiny sponges, scrubbing pollution out of the air and washing it down
      to the ground. This is called \u201Cwet deposition.\u201D"
    correctAnswer: 1
  - answer: False
    messageWhenChosen: "Oops! Rain gives the sky a bath. Raindrops and snowflakes
      act like tiny sponges, scrubbing pollution out of the air and washing it down
      to the ground. This is called \u201Cwet deposition.\u201D "
    correctAnswer: 0
