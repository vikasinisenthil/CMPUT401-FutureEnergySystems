  m_Script: {fileID: 11500000, guid: 88074e2e0d4f0b8478a99308a4b0d6a4, type: 3}
  m_Name: DeliveryHabit
  m_EditorClassIdentifier: GameScripts::BlueMCQCard
  cardName: The Delivery Habit
  image: {fileID: 21300000, guid: 757d9fca2e168514abbe246f52f797d9, type: 3}
  statement: 
  question: ' I want to buy 5 different gifts online for my friends. Which is the
    most Earth-friendly way to order them?'
  answers:
  - answer: 'Order them separately, so each one arrives on a different day. '
    messageWhenChosen: 'Oops! Five little boxes means five times the delivery trips!
      More cars on the road means more pollution. Buying all your online gifts together
      is better for the Earth. '
    correctAnswer: 0
  - answer: Order them together, so they all arrive on the same day.
    messageWhenChosen: Correct! Five little boxes means five times the delivery trips!
      More cars on the road means more pollution. Buying all your online gifts together
      is better for the Earth.
    correctAnswer: 1
  - answer: It makes no difference.
    messageWhenChosen: 'Oops! Five little boxes means five times the delivery trips!
      More cars on the road means more pollution. Buying all your online gifts together
      is better for the Earth. '
    correctAnswer: 0
