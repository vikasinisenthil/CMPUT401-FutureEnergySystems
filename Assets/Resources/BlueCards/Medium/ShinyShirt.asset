  m_Script: {fileID: 11500000, guid: 88074e2e0d4f0b8478a99308a4b0d6a4, type: 3}
  m_Name: ShinyShirt
  m_EditorClassIdentifier: GameScripts::BlueMCQCard
  cardName: The Shiny Shirt
  image: {fileID: 21300000, guid: dcf8f75cf7a71644f914af3bab9baec7, type: 3}
  statement: 
  question: "If the arctic ice melts and turns into dark ocean water, what happens
    to Earth\u2019s temperature? Hint: Think about how you feel outside when you
    wear a white shirt, compared to a black shirt). "
  answers:
  - answer: 'The Earth will heat up more. '
    messageWhenChosen: 'Correct! Dark colors absorb more heat, while light colors
      reflect it. If the white arctic ice melts, turning into dark colored water,
      the Earth will start to heat up faster. '
    correctAnswer: 1
  - answer: The Earth will start to cool down.
    messageWhenChosen: 'Oops! Dark colors absorb more heat, while light colors reflect
      it. If the white arctic ice melts, turning into dark colored water, the Earth
      will start to heat up faster. '
    correctAnswer: 0
