  m_Script: {fileID: 11500000, guid: 88074e2e0d4f0b8478a99308a4b0d6a4, type: 3}
  m_Name: EarthsJacket
  m_EditorClassIdentifier: GameScripts::BlueMCQCard
  cardName: "The Earth\u2019s Jacket"
  image: {fileID: 21300000, guid: edb3ebd33e7146c489b83946e1cd46dc, type: 3}
  statement: 
  question: 'True or False - We need greenhouse gases, like carbon dioxide, to keep
    Earth healthy. '
  answers:
  - answer: True
    messageWhenChosen: "True! Greenhouse gases, like CO2 and water vapour, act like
      a cozy blanket. Without them, Earth would be a frozen ice ball (-18C)! We need
      the blanket\u2014but if we have too many layers, Earth gets TOO hot."
    correctAnswer: 1
  - answer: False
    messageWhenChosen: "Oops! Greenhouse gases, like CO2 and water vapour, act like
      a cozy blanket. Without them, Earth would be a frozen ice ball (-18C)! We need
      the blanket\u2014but if we have too many layers, Earth gets TOO hot."
    correctAnswer: 0
