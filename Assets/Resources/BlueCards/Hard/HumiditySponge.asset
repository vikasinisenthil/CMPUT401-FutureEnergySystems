  m_Name: HumiditySponge
  m_EditorClassIdentifier: GameScripts::BlueMCQCard
  cardName: The Humidity Sponge
  image: {fileID: 21300000, guid: 6a3482ee799151d4b89536a033c9b862, type: 3}
  statement: 
  question: True or False - Cold air can hold more water than warm air.
  answers:
  - answer: True
    messageWhenChosen: "Oops! Warm air is a bigger sponge than cold air, because
      it has more energy to hold onto water vapour. When warm, wet air cools down
      suddenly, it can\u2019t hold onto the water anymore \u2013 so it rains! "
    correctAnswer: 0
  - answer: False
    messageWhenChosen: "False! Warm air is a bigger sponge than cold air, because
      it has more energy to hold onto water vapour. When warm, wet air cools down
      suddenly, it can\u2019t hold onto the water anymore \u2013 so it rains!"
    correctAnswer: 1
